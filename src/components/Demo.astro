---
interface Props { t: any; }
const { t } = Astro.props;

const steps = [
  { number: t.demo.step1number, title: t.demo.step1title, body: t.demo.step1body },
  { number: t.demo.step2number, title: t.demo.step2title, body: t.demo.step2body },
  { number: t.demo.step3number, title: t.demo.step3title, body: t.demo.step3body },
];
---
<section id="how-it-works" class="py-20 md:py-32 px-6 border-t border-rule">
  <div class="max-w-[960px] mx-auto">
    <p class="text-[11px] font-semibold uppercase tracking-[.3em] text-mute mb-16 reveal">{t.demo.label}</p>

    <div class="grid md:grid-cols-3 gap-0">
      {steps.map((step, i) => (
        <div class={`relative md:pr-12 ${i > 0 ? 'mt-12 md:mt-0 md:pl-12 md:border-l border-rule' : ''} reveal ${i === 1 ? 'd1' : i === 2 ? 'd2' : ''}`}>
          <p class="font-display font-800 text-[clamp(2.5rem,5vw,4rem)] leading-none tracking-tight text-mute/20 select-none mb-6">
            {step.number}
          </p>
          <h3 class="font-display font-700 text-[clamp(1.1rem,2vw,1.35rem)] tracking-tight leading-snug mb-3">
            {step.title}
          </h3>
          <p class="text-mute text-[14px] leading-relaxed">
            {step.body}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
