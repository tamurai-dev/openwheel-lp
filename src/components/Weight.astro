---
interface Props { t: any; }
const { t } = Astro.props;
const questions = [t.problem.q1, t.problem.q2, t.problem.q3, t.problem.q4];
---
<section class="py-32 md:py-44 px-6 border-t border-rule">
  <div class="max-w-[1120px] mx-auto">
    <p class="text-[clamp(1.5rem,3.5vw,2.25rem)] font-light leading-snug max-w-[640px] reveal">
      {t.problem.lead}
    </p>
    <p class="text-[clamp(1.5rem,3.5vw,2.25rem)] font-semibold leading-snug max-w-[640px] mt-4 reveal d1">
      {t.problem.but}
    </p>

    <div class="mt-16 flex flex-col gap-3 max-w-[480px] reveal d2">
      {questions.map((q) => (
        <p class="text-mute text-[15px] leading-relaxed pl-5 border-l-2 border-rule">
          {q}
        </p>
      ))}
    </div>

    <p class="text-[clamp(1.3rem,3vw,2rem)] font-semibold leading-snug max-w-[640px] mt-16 reveal d3">
      {t.problem.after}
    </p>
  </div>
</section>
