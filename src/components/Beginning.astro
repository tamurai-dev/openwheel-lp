---
interface Props { t: any; }
const { t } = Astro.props;
---
<section id="contact" class="py-32 md:py-48 px-6 border-t border-rule">
  <div class="max-w-[1120px] mx-auto">
    <h2 class="font-display font-800 text-[clamp(3rem,9vw,7rem)] leading-[0.95] tracking-tight reveal">
      {t.cta.line}
    </h2>
    <p class="text-mute text-[15px] mt-6 reveal d1">{t.cta.contactNote}</p>
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 mt-10 reveal d1">
      <a
        href={t.cta.contactHref}
        target="_blank"
        rel="noopener noreferrer"
        class="text-[14px] font-semibold tracking-wide bg-fg text-bg px-6 py-3 rounded-full hover:opacity-80 transition-opacity"
      >
        {t.cta.contactLabel}
      </a>
      <a
        href={t.cta.demoHref}
        class="text-[13px] tracking-wide text-mute hover:text-fg transition-colors"
      >
        {t.cta.demoLabel} ↑
      </a>
    </div>
  </div>
</section>
