---
interface Props { t: any; }
const { t } = Astro.props;
---
<section class="min-h-[100svh] flex flex-col justify-end px-6 pb-20">
  <div class="max-w-[1120px] mx-auto w-full">
    <p class="text-[11px] font-semibold uppercase tracking-[.3em] text-mute mb-10 hero-in">{t.hero.label}</p>
    <h1 class="font-display font-800 leading-[0.95] tracking-[-0.03em]">
      <span class="block text-[clamp(3rem,8.5vw,7rem)] hero-in hero-in-d1">{t.hero.line1}</span>
      <span class="block text-[clamp(3rem,8.5vw,7rem)] hero-in hero-in-d2">{t.hero.line2}</span>
    </h1>
    <p class="max-w-[480px] text-mute text-[15px] leading-relaxed mt-10 hero-in hero-in-d3">
      {t.hero.description}
    </p>
    <div class="flex items-center gap-5 mt-8 hero-in hero-in-d4">
      <a
        href={t.hero.ctaContactHref}
        class="inline-block text-[13px] font-semibold tracking-wide bg-fg text-bg px-5 py-2.5 rounded-full hover:opacity-80 transition-opacity"
      >
        {t.hero.ctaContact}
      </a>
      <a
        href={t.hero.ctaHref}
        class="inline-block text-[13px] tracking-wide text-mute hover:text-fg transition-colors"
      >
        {t.hero.cta} ↑
      </a>
    </div>
  </div>
</section>
