---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import ChatHero from "../../components/ChatHero.astro";
import Cover from "../../components/Cover.astro";
import Demo from "../../components/Demo.astro";
import Weight from "../../components/Weight.astro";
import Foundation from "../../components/Foundation.astro";
import Story from "../../components/Story.astro";
import Philosophy from "../../components/Philosophy.astro";
import Beginning from "../../components/Beginning.astro";
import Footer from "../../components/Footer.astro";
import { t } from "../../i18n";

const i = t("en");
---

<Layout
  title="OpenWheel — Words become agents"
  lang="en"
  description="Define your intent in natural language. OpenWheel generates production-ready AI agents on Claude Managed Agents."
>
  <Nav t={i} />
  <main>
    <ChatHero t={i} />
    <Cover t={i} />
    <Demo t={i} />
    <Weight t={i} />
    <Foundation t={i} />
    <Story t={i} />
    <Philosophy t={i} />
    <Beginning t={i} />
  </main>
  <Footer t={i} />
</Layout>
