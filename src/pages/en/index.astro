---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import ChatHero from "../../components/ChatHero.astro";
import Cover from "../../components/Cover.astro";
import Demo from "../../components/Demo.astro";
import Weight from "../../components/Weight.astro";
import Questions from "../../components/Questions.astro";
import Foundation from "../../components/Foundation.astro";
import Cloud from "../../components/Cloud.astro";
import SaasLayer from "../../components/SaasLayer.astro";
import Story from "../../components/Story.astro";
import Philosophy from "../../components/Philosophy.astro";
import Beginning from "../../components/Beginning.astro";
import Footer from "../../components/Footer.astro";
import { t } from "../../i18n";

const i = t("en");
---

<Layout
  title="OpenWheel — AI that rides on your tools"
  lang="en"
  description="Shopify, BASE, your own database — OpenWheel puts a custom AI agent on top of the tools you already use. No technical skills required."
>
  <Nav t={i} />
  <main>
    <ChatHero t={i} />
    <Cover t={i} />
    <Weight t={i} />
    <Questions t={i} />
    <Demo t={i} />
    <Foundation t={i} />
    <Cloud t={i} />
    <SaasLayer t={i} />
    <Story t={i} />
    <Philosophy t={i} />
    <Beginning t={i} />
  </main>
  <Footer t={i} />
</Layout>
