---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import Cover from "../../components/Cover.astro";
import Weight from "../../components/Weight.astro";
import Foundation from "../../components/Foundation.astro";
import Transformation from "../../components/Transformation.astro";
import Story from "../../components/Story.astro";
import Philosophy from "../../components/Philosophy.astro";
import Beginning from "../../components/Beginning.astro";
import Footer from "../../components/Footer.astro";
import { t } from "../../i18n";

const i = t("ja");
---

<Layout
  title="OpenWheel — 言葉が、エージェントになる"
  lang="ja"
  description="自然言語で意図を定義するだけで、本番環境のAIエージェントを自動生成。OpenWheel + Claude Managed Agents。"
>
  <Nav t={i} />
  <main>
    <Cover t={i} />
    <Weight t={i} />
    <Foundation t={i} />
    <Transformation t={i} />
    <Story t={i} />
    <Philosophy t={i} />
    <Beginning t={i} />
  </main>
  <Footer t={i} />
</Layout>
