---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import ChatHero from "../../components/ChatHero.astro";
import Cover from "../../components/Cover.astro";
import Demo from "../../components/Demo.astro";
import Weight from "../../components/Weight.astro";
import Foundation from "../../components/Foundation.astro";
import Cloud from "../../components/Cloud.astro";
import Story from "../../components/Story.astro";
import Philosophy from "../../components/Philosophy.astro";
import Beginning from "../../components/Beginning.astro";
import Footer from "../../components/Footer.astro";
import { t } from "../../i18n";

const i = t("ja");
---

<Layout
  title="OpenWheel — あなたの言葉が、エージェントになる"
  lang="ja"
  description="課題を書くか、URLを貼るだけ。OpenWheelが本番で動くAIエージェントを生成し、クラウドで稼働させる。"
>
  <Nav t={i} />
  <main>
    <ChatHero t={i} />
    <Cover t={i} />
    <Demo t={i} />
    <Weight t={i} />
    <Foundation t={i} />
    <Cloud t={i} />
    <Story t={i} />
    <Philosophy t={i} />
    <Beginning t={i} />
  </main>
  <Footer t={i} />
</Layout>
